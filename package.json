{
  "name": "gymflow",
  "version": "0.1.0",
  "private": true,
  "author": {
    "name": "Khubaib Shah",
    "email": "syedkhubaibshah@icloud.com",
    "url": "https://www.thekhubaib.me/"
    
  },
  "scripts": {
    "dev": "concurrently \"vite\" \"tsup --watch\" \"wait-on tcp:5173 dist-electron/main.js && electron .\"",
    "build": "vite build && tsup && node safe-build.js",
    "electron": "electron ."
  },
  "build": {
    "appId": "com.gymflow.saas",
    "productName": "Gymflow Desktop",
    "icon": "public/assets/logo/logo3.png",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "prisma/**/*"
    ],
    "extraResources": [
      {
        "from": "prisma/dev.db",
        "to": "dev.db"
      }
    ],
    "asarUnpack": [
      "prisma/**/*",
      "node_modules/@prisma/client/**/*",
      "node_modules/.prisma/client/**/*"
    ],
    "win": {
      "target": [
        "nsis"
      ]
    }
  },
  "main": "dist-electron/main.js",
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^3.0.3",
    "node-zklib": "^1.3.0",
    "sqlite3": "^6.0.1",
    "twilio": "^6.0.2"
  },
  "devDependencies": {
    "@babel/runtime": "^7.29.2",
    "@hookform/resolvers": "^3.10.0",
    "@radix-ui/react-accordion": "1.2.2",
    "@radix-ui/react-alert-dialog": "1.1.4",
    "@radix-ui/react-aspect-ratio": "1.1.1",
    "@radix-ui/react-avatar": "1.1.2",
    "@radix-ui/react-checkbox": "1.1.3",
    "@radix-ui/react-collapsible": "1.1.2",
    "@radix-ui/react-context-menu": "2.2.4",
    "@radix-ui/react-dialog": "1.1.4",
    "@radix-ui/react-dropdown-menu": "2.1.4",
    "@radix-ui/react-hover-card": "1.1.4",
    "@radix-ui/react-label": "2.1.1",
    "@radix-ui/react-menubar": "1.1.4",
    "@radix-ui/react-navigation-menu": "1.2.3",
    "@radix-ui/react-popover": "1.1.4",
    "@radix-ui/react-progress": "1.1.1",
    "@radix-ui/react-radio-group": "1.2.2",
    "@radix-ui/react-scroll-area": "1.2.2",
    "@radix-ui/react-select": "2.1.4",
    "@radix-ui/react-separator": "1.1.1",
    "@radix-ui/react-slider": "1.2.2",
    "@radix-ui/react-slot": "1.1.1",
    "@radix-ui/react-switch": "1.1.2",
    "@radix-ui/react-tabs": "1.1.2",
    "@radix-ui/react-toast": "1.2.4",
    "@radix-ui/react-toggle": "1.1.1",
    "@radix-ui/react-toggle-group": "1.1.1",
    "@radix-ui/react-tooltip": "1.1.6",
    "@tailwindcss/postcss": "^4.1.9",
    "@tanstack/react-table": "^8.21.3",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22",
    "@types/nodemailer": "^7.0.11",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.2",
    "autoprefixer": "^10.4.20",
    "baseline-browser-mapping": "^2.9.11",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "1.0.4",
    "concurrently": "^10.0.0",
    "date-fns": "4.1.0",
    "electron": "^42.3.0",
    "electron-builder": "^26.8.1",
    "immer": "latest",
    "input-otp": "1.4.1",
